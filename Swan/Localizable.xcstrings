    "swerror.foundation.noinstallassistant" : {
      "comment" : "You got this. :D",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No InstallAssistant.pkg links were found in the provided catalog. It may be too old (only Big Sur and newer are supported currently)."
          }
        }
      }
    },
    "swerror.foundation.nonhttpresponse" : {
      "comment" : "This is the kind of error that doesn't make sense to begin with, so don't worry yourself if it doesn't make any sense.",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Received response was not of the HTTP type. "
          }
        }
      }
    },
    "swerror.foundation.standardhttp" : {
      "comment" : "400 = Success, literally anything else means something went wrong. DO NOT LOCALIZE <DATA>, it will be automatically replaced with the received status code (200, 501, etc).",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Received non-200 HTTP status code, instead received <DATA>."
          }
        }
      }
    },
    "swerror.foundation.unknown" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "An unknown error occurred. <DATA>"
          }
        }
      }
    },
    "swerror.product.unknown" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unknown product type attempted to be resolved. This may be solved in a future app version."
          }
        }
      }
    },
    "swerror.reader.invalidenglishdistributionurl" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The English distribution URL is invalid. This could be Apple’s fault (a note would most likely be pinned in the GitHub issues page), or it could be a bug. "
          }
        }
      }
    },
    "swerror.reader.noenglishdistribution" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "There is no English distribution URL on this product, which is required to obtain additional specific information (like version and build number) on it."
          }
        }
      }
    },
    "swerror.reader.nonhttpresponse" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The response that we got from an HTTP request was not an HTTP response. I don’t know how you managed this."
          }
        }
      }
    },
    "swerror.reader.regexcreation" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The regex couldn’t be created because it probably wasn’t in the right format. This is a bug, please report on GitHub."
          }
        }
      }
    },
    "swerror.reader.regexnoextraction" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Regex failed to extract the correct information, this may be a bug or a change in format on Apple’s behalf, please check GitHub."
          }
        }
      }
    },
    "swerror.reader.regexnomatch" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Regex failed to match any information, this may be a bug or a change in format on Apple’s behalf, please check GitHub."
          }
        }
      }
    },
    "swerror.reader.standardhttp" : {
      "comment" : "200 = Success, literally anything else means something went wrong. DO NOT LOCALIZE <DATA>, it will be automatically replaced with the received status code (404, 501, 327, etc).",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Received non-400 HTTP status code, instead received <DATA>."
          }
        }
      }
    },
    "swerror.reader.utf8conversion" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The reader could not convert the data to UTF8 text. This is unexpected, and unprecedented."
          }
        }
      }
    },
    "swerror.reader.versionlessthan10" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This product has a major version less than 10. If you’re new to macOS, that was before you were born. That shouldn’t be in the catalog, especially knowing it normally only shows 10.13 and later with installers. Good job man."
          }
        }
      }
    },
    "swerror.reader.versionminor" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
